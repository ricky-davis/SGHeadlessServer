<Project>
  <PropertyGroup>
    <WindowsGamePath>C:\Program Files (x86)\Steam\steamapps\common\Sledding Game</WindowsGamePath>
    <LinuxGamePath>/mnt/c/Program Files (x86)/Steam/steamapps/common/Sledding Game</LinuxGamePath>

    <GamePath Condition="'$(GamePath)' == '' and Exists('$(WindowsGamePath)')">$(WindowsGamePath)</GamePath>
    <GamePath Condition="'$(GamePath)' == '' and Exists('$(LinuxGamePath)')">$(LinuxGamePath)</GamePath>
    <GamePath Condition="'$(GamePath)' == ''">$(WindowsGamePath)</GamePath>
    <RefRoot Condition="'$(RefRoot)' == '' and Exists('$(GamePath)/MelonLoader')">$(GamePath)/MelonLoader</RefRoot>
    <RefRoot Condition="'$(RefRoot)' == ''">$(GamePath)/MelonLoader</RefRoot>

    <DeployMod Condition="'$(DeployMod)' == '' and Exists('$(GamePath)')">true</DeployMod>
    <DeployMod Condition="'$(DeployMod)' == ''">false</DeployMod>
  </PropertyGroup>
  <PropertyGroup>
    <!-- Centralized package/project version and author -->
    <Version>1.0.0</Version>
    <Authors>Spyci</Authors>
  </PropertyGroup>
</Project>
