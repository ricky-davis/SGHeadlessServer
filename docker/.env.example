# Copy to .env and edit.  `docker compose` reads this file automatically.

# --- Runtime user ---------------------------------------------------------------------
# Match these to the owner of your host GameData so written files (logs, prefs) stay yours.
#   id -u  /  id -g
PUID=1000
PGID=1000

# --- Game files -----------------------------------------------------------------------
# Path on the host to your prepared GameData (game + MelonLoader + Mods), mounted at
# /game inside the container. See README.md for how to copy it in.
GAME_DIR_HOST=./GameData

# --- Proton ---------------------------------------------------------------------------
# Any GE-Proton release tag: https://github.com/GloriousEggroll/proton-ge-custom/releases
PROTON_VERSION=GE-Proton9-20
